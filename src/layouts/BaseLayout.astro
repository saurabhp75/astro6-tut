---
import "../styles/global.css";

const pathname = Astro.url.pathname;
const isActive = (href: string) => href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
const navLinkClass = (href: string) =>
    `inline-flex rounded-full border px-4 py-2 transition ${
        isActive(href)
            ? "border-sky-400 bg-sky-400/10 text-sky-300 shadow-lg shadow-sky-950/40"
            : "border-white/10 bg-slate-900/80 text-slate-200 hover:border-sky-400 hover:text-sky-300"
    }`;
---

<html lang="en" class="bg-slate-950 text-slate-100">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Book Bites</title>
    </head>
    <body class="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 antialiased">
        <div class="mx-auto flex min-h-screen max-w-5xl flex-col px-6 py-8 sm:px-8 lg:px-10">
            <header class="mb-10 rounded-2xl border border-white/10 bg-white/5 px-6 py-5 shadow-2xl shadow-slate-950/30 backdrop-blur">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <p class="text-sm font-medium uppercase tracking-[0.3em] text-sky-300">Astro + Tailwind</p>
                        <h1 class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">Book Bites</h1>
                    </div>

                    <nav>
                        <ul class="flex flex-wrap gap-2 text-sm font-medium text-slate-200">
                            <li>
                                <a class={navLinkClass("/")} href="/" aria-current={isActive("/") ? "page" : undefined}>Home</a>
                            </li>
                            <li>
                                <a class={navLinkClass("/about")} href="/about" aria-current={isActive("/about") ? "page" : undefined}>About</a>
                            </li>
                            <li>
                                <a class={navLinkClass("/books")} href="/books" aria-current={isActive("/books") ? "page" : undefined}>Books</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </header>

            <main class="flex-1 rounded-2xl border border-white/10 bg-slate-900/60 p-6 shadow-xl shadow-slate-950/20 backdrop-blur sm:p-8">
                <div class="prose prose-invert max-w-none prose-headings:text-white prose-p:text-slate-300 prose-a:text-sky-300">
                    <slot />
                </div>
            </main>
        </div>
    </body>
</html>
