---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const books = await getCollection("books");

    return books.map((book) => {
        return {
            params: { id: book.id },
            props: { book },
        };
    });
}

const { book } = Astro.props;
const { Content } = await render(book);
---

<BaseLayout>
    <div class="space-y-6 rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-slate-950/20 backdrop-blur sm:p-8 [&_h3]:mt-8 [&_h3]:text-3xl [&_h3]:font-bold [&_h3]:tracking-tight [&_h3]:text-white [&_h3]:first:mt-0 [&_p]:mt-4 [&_p]:text-base [&_p]:leading-7 [&_p]:text-slate-300">
        <Content />
    </div>
</BaseLayout>
