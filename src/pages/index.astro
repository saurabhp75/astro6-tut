---
import BaseLayout from "../layouts/BaseLayout.astro";

const getUser = () => {
    return Math.random() < 0.5
        ? null
        : {
              name: "Saurabh",
              email: "saurabh@gmail.com",
          };
};

let user = getUser();
---

<BaseLayout>
    <section
        class="not-prose overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-2xl shadow-slate-950/30"
    >
        <div
            class="bg-linear-to-r from-sky-400/10 via-slate-900/40 to-transparent px-6 py-10 sm:px-8 sm:py-12"
        >
        {user && (
            <h2
                class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-300"
            >
                Welcome, {user.name}
            </h2>
            <!-- <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">Fresh perspectives on unforgettable books</h2> -->
            <p
                class="mt-4 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg"
            >
                Logged in as {user.email}
            </p>
		)}

            <div class="mt-8 flex flex-wrap gap-3">
                <a
                    href="/books"
                    class="inline-flex rounded-full border border-sky-400 bg-sky-400/10 px-5 py-2.5 text-sm font-semibold text-sky-300 shadow-lg shadow-sky-950/40 transition hover:bg-sky-400/20"
                >
                    Browse book reviews
                </a>
                <a
                    href="/about"
                    class="inline-flex rounded-full border border-white/10 bg-slate-900/80 px-5 py-2.5 text-sm font-semibold text-slate-200 transition hover:border-sky-400 hover:text-sky-300"
                >
                    Learn more
                </a>
            </div>
        </div>

        <!-- <div class="grid gap-4 border-t border-white/10 bg-slate-950/40 px-6 py-6 sm:grid-cols-3 sm:px-8">
            <div class="rounded-xl border border-white/10 bg-slate-900/70 p-4">
                <p class="text-sm font-medium text-sky-300">Curated picks</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">Find books that are memorable, insightful, and worth recommending.</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-slate-900/70 p-4">
                <p class="text-sm font-medium text-sky-300">Short reviews</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">Get the key takeaways quickly with clear, reader-friendly summaries.</p>
            </div>
            <div class="rounded-xl border border-white/10 bg-slate-900/70 p-4">
                <p class="text-sm font-medium text-sky-300">Thoughtful notes</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">Explore what makes each book resonate beyond its final page.</p>
            </div>
        </div> -->
    </section>
</BaseLayout>
