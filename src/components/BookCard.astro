---
import type { CollectionEntry } from "astro:content";

interface Props {
    book: CollectionEntry<"books">;
}

const { book } = Astro.props;
---

<div
    class="rounded-2xl border border-white/10 bg-white/5 p-5 shadow-lg shadow-slate-950/20 backdrop-blur transition hover:border-sky-400/40 hover:bg-white/10"
>
    <p class="text-xl font-semibold text-white">
        {book.data.title}, {book.data.rating}/10
    </p>
    <p class="mt-2 text-sm text-slate-400 italic">by {book.data.author}</p>
    <p class="mt-2 text-sm text-slate-300">{book.data.summary}</p>
    <a
        class="mt-4 inline-flex text-sm font-medium text-sky-300 transition hover:text-sky-200"
        href={`/books/${book.id}`}
    >
        Read Review
    </a>
</div>
